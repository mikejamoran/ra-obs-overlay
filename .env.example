# RA Achievement Overlay — environment configuration
# Copy this to .env and fill in your values

# RetroAchievements credentials (optional: can also be entered via setup page)
RA_USERNAME=
RA_API_KEY=

# Setup page basic auth — leave blank to disable auth (not recommended for public servers)
SETUP_USER=admin
SETUP_PASS=changeme

# Twitch chat integration (optional: can also be connected via setup page)
# Get your token at: https://twitchapps.com/tmi/
TWITCH_CHANNEL=
TWITCH_TOKEN=

# Port (default: 7890)
PORT=7890
