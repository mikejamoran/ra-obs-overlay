# RA Achievement Overlay — environment configuration
# Copy this to .env and fill in your values

# RetroAchievements credentials (optional: can also be entered via setup page)
RA_USERNAME=
RA_API_KEY=

# Setup page basic auth — leave blank to disable auth (not recommended for public servers)
SETUP_USER=admin
SETUP_PASS=changeme

# Twitch chat integration & alerts
# 1. Create an app at https://dev.twitch.tv/console/apps/create
# 2. Set OAuth Redirect URL to: https://yourdomain.com/auth/twitch/callback
# 3. Copy Client ID and Client Secret here, then use "Connect with Twitch" in the setup page
# Requested scopes: chat:read chat:edit channel:read:redemptions
#                   channel:read:subscriptions moderator:read:followers
# (channel points / subs / follows alerts need the last three — reconnect
#  with Twitch from the setup page if you authorized before they were added)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Legacy: fallback token if not using OAuth (deprecated, prefer the OAuth flow above)
TWITCH_CHANNEL=
TWITCH_TOKEN=

# Port (default: 7890)
PORT=7890

# Testing only: point EventSub + Helix at the Twitch CLI mock server
# (`twitch event websocket start-server`) instead of production Twitch
# EVENTSUB_WS_URL=ws://127.0.0.1:8080/ws
# TWITCH_HELIX_URL=http://127.0.0.1:8080
