# RA Achievement Overlay — environment configuration
# Copy this to .env and fill in your values

# RetroAchievements credentials (optional: can also be entered via setup page)
RA_USERNAME=
RA_API_KEY=

# Setup page basic auth — leave blank to disable auth (not recommended for public servers)
SETUP_USER=admin
SETUP_PASS=changeme

# Twitch chat integration
# 1. Create an app at https://dev.twitch.tv/console/apps/create
# 2. Set OAuth Redirect URL to: https://yourdomain.com/auth/twitch/callback
# 3. Copy Client ID and Client Secret here, then use "Connect with Twitch" in the setup page
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Legacy: fallback token if not using OAuth (deprecated, prefer the OAuth flow above)
TWITCH_CHANNEL=
TWITCH_TOKEN=

# Port (default: 7890)
PORT=7890
